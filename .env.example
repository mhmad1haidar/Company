# Copy to .env and adjust. Never commit .env with real secrets.

DJANGO_SETTINGS_MODULE=company.settings.development

# Required in production (company.settings.production fails fast if still default)
SECRET_KEY=change-me-in-production-use-long-random-string

DEBUG=True

# Comma-separated hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# Dev only: allow any origin (set False when testing a specific frontend)
CORS_ALLOW_ALL_ORIGINS=True

# Attendance: late if local check-in after this time (default 09:00)
# ATTENDANCE_LATE_HOUR=9
# ATTENDANCE_LATE_MINUTE=0

# Database URL (optional). Example for Postgres:
# DATABASE_URL=postgres://user:pass@localhost:5432/company_db
# If unset, SQLite is used (development).

# --- Security Settings ---
# CSRF trusted origins for production (comma-separated)
# CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Session and CSRF security
# SESSION_COOKIE_AGE=3600
# CSRF_COOKIE_AGE=3600

# --- Production (company.settings.production) ---
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SECURE_SSL_HOST=your-domain.com
# SECURE_REDIRECT_EXEMPT=/health,/api/health

# API Security
# API_ENABLE_BASIC_AUTH=False

# CORS for production (comma-separated)
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com
